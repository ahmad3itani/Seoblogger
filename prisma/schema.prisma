generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER & AUTH ───────────────────────────────────────────
// User.id matches Supabase auth.users.id (UUID)
model User {
  id            String    @id @db.Uuid
  email         String    @unique
  name          String?
  avatarUrl     String?
  
  // Role-based access
  role          String    @default("user") // user, admin
  
  // Subscription & Billing
  planId         String?
  plan           Plan?     @relation(fields: [planId], references: [id])
  subscription   Subscription?
  
  // Stripe Integration
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripeSubscriptionStatus String? // active, canceled, past_due, etc.
  stripePriceId          String?   // Current price ID
  stripeCurrentPeriodEnd DateTime?
  
  // Usage Tracking
  usage          Usage?
  
  // Google OAuth tokens for Blogger API
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  // Relations
  blogs         Blog[]
  projects      Project[]
  brandProfiles BrandProfile[]
  campaigns     Campaign[]
  articles      Article[]
  fixHistory    FixHistory[]
  scanReports   ScanReport[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── PLANS & BILLING ──────────────────────────────────────
model Plan {
  id            String   @id @default(cuid())
  name          String   @unique // free, starter, pro, enterprise
  displayName   String
  stripePriceId String?  @unique // Stripe Price ID for this plan
  description   String?
  price         Float    @default(0)
  yearlyPrice   Float?
  
  // Feature Limits
  articlesPerMonth    Int   @default(10)
  imagesPerMonth      Int   @default(30)
  blogsLimit          Int   @default(1)
  projectsLimit       Int   @default(1)
  brandProfilesLimit  Int   @default(1)
  campaignsLimit      Int   @default(0)
  wordsPerArticle     Int   @default(2000)
  
  // Feature Flags
  hasAutoPublish        Boolean @default(false)
  hasScheduling         Boolean @default(false)
  hasAnalytics          Boolean @default(false)
  hasBulkGeneration     Boolean @default(false)
  hasTrendIdeas         Boolean @default(false)
  hasAutoClustering     Boolean @default(false)
  hasContentRefresh     Boolean @default(false)
  hasApiAccess          Boolean @default(false)
  hasPrioritySupport    Boolean @default(false)
  hasWhiteLabel         Boolean @default(false)
  hasTeamAccess         Boolean @default(false)
  teamMembersLimit      Int     @default(1)
  hasAdvancedAI         Boolean @default(false)
  hasCompetitorAnalysis Boolean @default(false)
  hasCustomPrompts      Boolean @default(false)
  
  // Stripe (stripePriceId already defined above on line 58)
  stripeYearlyPriceId String?
  
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  users         User[]
  subscriptions Subscription[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId            String
  plan              Plan     @relation(fields: [planId], references: [id])
  
  status            String   @default("active") // active, canceled, past_due, trialing, expired
  billingCycle      String   @default("monthly") // monthly, yearly
  
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  
  // Stripe
  stripeCustomerId      String?
  stripeSubscriptionId  String? @unique
  stripePaymentMethodId String?
  
  // Trial
  trialStart    DateTime?
  trialEnd      DateTime?
  
  // Cancellation
  cancelAtPeriodEnd Boolean  @default(false)
  canceledAt        DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Usage {
  id        String   @id @default(cuid())
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Current period
  articlesGenerated   Int @default(0)
  imagesGenerated     Int @default(0)
  apiCallsCount       Int @default(0)
  wordsGenerated      Int @default(0)
  
  // Lifetime
  totalArticles       Int @default(0)
  totalImages         Int @default(0)
  totalWords          Int @default(0)
  totalApiCalls       Int @default(0)
  
  lastResetAt         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── BLOG & CONTENT ───────────────────────────────────────
model Blog {
  id          String   @id @default(cuid())
  blogId      String   @unique
  name        String
  url         String
  description String?
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault   Boolean  @default(false)
  articles    Article[]
  publishLogs PublishLog[]
  cachedPosts CachedPost[]
  siteAudits  SiteAudit[]
  crawlSessions CrawlSession[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  niche       String?
  language    String   @default("en")
  country     String   @default("US")
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords    Keyword[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Keyword {
  id          String   @id @default(cuid())
  keyword     String
  searchIntent String?
  articleType  String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  articles    Article[]
  createdAt   DateTime @default(now())
}

model Article {
  id              String   @id @default(cuid())
  title           String
  slug            String?
  content         String
  outline         String?
  metaDescription String?
  excerpt         String?
  labels          String?
  tone            String   @default("informational")
  articleType     String   @default("blog-post")
  wordCount       Int      @default(0)
  status          String   @default("draft")
  scheduledFor    DateTime?
  bloggerPostId   String?
  keywordId       String?
  keyword         Keyword? @relation(fields: [keywordId], references: [id])
  blogId          String?
  blog            Blog?    @relation(fields: [blogId], references: [id])
  userId          String?  @db.Uuid
  user            User?    @relation(fields: [userId], references: [id])
  images          GeneratedImage[]
  publishLogs     PublishLog[]
  qualityPasses   QualityPassRun[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GeneratedImage {
  id          String   @id @default(cuid())
  url         String
  altText     String?
  type        String   @default("featured")
  articleId   String?
  article     Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model PublishLog {
  id            String   @id @default(cuid())
  action        String
  bloggerPostId String?
  blogId        String
  blog          Blog     @relation(fields: [blogId], references: [id])
  articleId     String
  article       Article  @relation(fields: [articleId], references: [id])
  response      String?
  createdAt     DateTime @default(now())
}

model CachedPost {
  id          String   @id @default(cuid())
  postId      String
  blogId      String
  blog        Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  title       String
  url         String
  contentHash String?  // To detect if content changed over time
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([blogId, postId])
}

model SiteAudit {
  id          String   @id @default(cuid())
  blogId      String
  blog        Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  score       Int      @default(0)
  issues      Json     @default("[]") // Array of issue objects
  runAt       DateTime @default(now())
}

// ─── CAMPAIGNS & BRAND ────────────────────────────────────
model Campaign {
  id            String   @id @default(cuid())
  name          String
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogId        String
  language      String   @default("en")
  tone          String   @default("professional")
  articleType   String   @default("informational")
  wordCount     Int      @default(2000)
  brandVoice    String?
  includeImages Boolean  @default(true)
  autoInterlink Boolean  @default(true)
  frequencyDays Int      @default(1)
  nextPublishAt DateTime @default(now())
  keywords      String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BrandProfile {
  id             String   @id @default(cuid())
  name           String
  tone           String   @default("professional")
  style          String?
  niche          String?
  language       String   @default("en")
  targetAudience String?
  instructions   String?
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  name        String
  type        String
  structure   String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── ADVANCED SEO SITE AUDIT ────────────────────────────────

model CrawlSession {
  id            String   @id @default(cuid())
  blogId        String
  blog          Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  status        String   @default("running") // running, completed, failed
  pagesScanned  Int      @default(0)
  totalScore    Int      @default(0)
  scannedPages  ScannedPage[]
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}

model ScannedPage {
  id               String   @id @default(cuid())
  sessionId        String
  session          CrawlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url              String
  title            String?
  metaDescription  String?
  h1               String?
  h2Count          Int      @default(0)
  wordCount        Int      @default(0)
  internalLinks    Int      @default(0)
  externalLinks    Int      @default(0)
  imagesCount      Int      @default(0)
  missingAltCount  Int      @default(0)
  statusCode       Int      @default(200)
  loadTimeMs       Int      @default(0)
  score            Int      @default(0)
  issues           SeoIssue[]
  createdAt        DateTime @default(now())
}

model SeoIssue {
  id              String   @id @default(cuid())
  pageId          String
  page            ScannedPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type            String   // technical, on_page, content, internal_link, image, performance
  issueId         String   // e.g., missing_meta_description
  severity        String   // high, medium, low
  description     String
  fixable         Boolean  @default(false)
  suggestion      FixSuggestion?
  createdAt       DateTime @default(now())
}

model FixSuggestion {
  id              String   @id @default(cuid())
  issueId         String   @unique
  issue           SeoIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  suggestedFix    String   // The text or HTML suggested
  explanation     String?  // Why it matters
  status          String   @default("pending") // pending, applied, rejected
  appliedAt       DateTime?
  createdAt       DateTime @default(now())
}

// ─── CONTENT REFRESH ENGINE ──────────────────────────────────

model RefreshCandidate {
  id             String    @id @default(cuid())
  userId         String    @db.Uuid
  blogId         String
  postId         String    // Blogger post ID
  url            String
  title          String
  publishedAt    DateTime?
  labels         String?   // Comma-separated labels

  // Scoring
  refreshScore   Int       @default(0)  // 0-100 composite score
  tier           Int       @default(3)  // 1=best opportunity, 2=declining, 3=weak legacy
  tierLabel      String    @default("weak_legacy") // best_opportunity, declining_asset, weak_legacy

  // Performance metrics (from Search Console)
  clicksLast28       Int?
  clicksPrev28       Int?
  impressionsLast28  Int?
  impressionsPrev28  Int?
  ctrLast28          Float?
  avgPositionLast28  Float?

  // Content signals (from crawler)
  wordCount          Int       @default(0)
  h2Count            Int       @default(0)
  internalLinks      Int       @default(0)
  externalLinks      Int       @default(0)
  imagesCount        Int       @default(0)
  missingAltCount    Int       @default(0)
  hasFaq             Boolean   @default(false)
  hasSchema          Boolean   @default(false)

  // Diagnosis summary
  reasonSummary      String?   @db.Text
  status             String    @default("detected") // detected, diagnosed, planned, refreshed, applied, verified

  // Relations
  diagnostic    RefreshDiagnostic?
  plans         RefreshPlan[]
  versions      RefreshVersion[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([blogId, postId])
  @@index([userId])
  @@index([refreshScore])
}

model RefreshDiagnostic {
  id               String   @id @default(cuid())
  candidateId      String   @unique
  candidate        RefreshCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Performance diagnosis
  performanceOpportunity  Int @default(0) // 0-100
  declineSignal           Int @default(0) // 0-100
  contentWeakness         Int @default(0) // 0-100
  freshnessAge            Int @default(0) // 0-100
  indexConfidence          Int @default(0) // 0-100

  // Content diagnosis
  introQuality            String  @default("unknown") // strong, adequate, weak, missing
  headingStructure        String  @default("unknown") // strong, adequate, weak, missing
  faqPresent              Boolean @default(false)
  conclusionPresent       Boolean @default(false)
  snippetReadiness        String  @default("unknown") // ready, partial, weak

  // Gap analysis
  missingSubtopics        Json    @default("[]") // Array of strings
  outdatedSignals         Json    @default("[]") // Array of strings (e.g., "references 2023")
  thinSections            Json    @default("[]") // Array of strings
  internalLinkOpportunity Int     @default(0) // How many links could be added

  // Raw data
  topQueries              Json    @default("[]") // Top search queries from GSC
  indexedStatus           String? // indexed, not_indexed, unknown

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model RefreshPlan {
  id               String   @id @default(cuid())
  candidateId      String
  candidate        RefreshCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Plan content
  mode             String   @default("section") // recommendation, section, full
  proposedOutline  Json     @default("[]") // Array of { heading, action: keep|expand|add|rewrite }
  proposedFaqs     Json     @default("[]") // Array of { question, answer }
  sectionsToExpand Json     @default("[]") // Array of section names
  subtopicsToAdd   Json     @default("[]") // Array of subtopic strings
  suggestedTitle   String?
  expectedImpact   String   @default("medium") // high, medium, low
  confidence       Int      @default(0) // 0-100

  // AI explanation
  whyRefresh       String?  @db.Text
  whatToAdd         String?  @db.Text
  whatToKeep        String?  @db.Text
  whatToRemove      String?  @db.Text

  status           String   @default("draft") // draft, approved, generating, completed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RefreshVersion {
  id               String   @id @default(cuid())
  candidateId      String
  candidate        RefreshCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Content
  oldTitle         String
  newTitle         String
  oldHtml          String   @db.Text
  newHtml          String   @db.Text

  // Change tracking
  sectionsExpanded   Json   @default("[]")
  subtopicsAdded     Json   @default("[]")
  faqsAdded          Int    @default(0)
  wordCountBefore    Int    @default(0)
  wordCountAfter     Int    @default(0)

  // Trust signals
  confidence         Int    @default(0) // 0-100
  aiModel            String @default("unknown")

  // Status
  status             String @default("draft") // draft, approved, applied, verified, rolled_back
  appliedBy          String? @db.Uuid
  appliedAt          DateTime?
  verifiedAt         DateTime?
  verificationNote   String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── HUMAN QUALITY PASS ──────────────────────────────────────

model QualityPassRun {
  id                  String    @id @default(cuid())
  articleId           String
  article             Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId              String    @db.Uuid

  // 6 category scores (0-100)
  readabilityScore    Int       @default(0)
  helpfulnessScore    Int       @default(0)
  originalityScore    Int       @default(0)
  naturalnessScore    Int       @default(0)
  trustScore          Int       @default(0)
  publishSafetyScore  Int       @default(0)
  overallScore        Int       @default(0)

  // Stage tracking
  stage1Complete      Boolean   @default(false) // Deterministic analysis
  stage2Complete      Boolean   @default(false) // Cheap model review
  stage3Complete      Boolean   @default(false) // Stronger model rewrite

  // Metadata
  modelUsed           String    @default("unknown")
  status              String    @default("analyzing") // analyzing, reviewed, rewritten, approved, applied
  durationMs          Int       @default(0)

  // Relations
  flags               QualityFlag[]
  versions            QualityVersion[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([articleId])
  @@index([userId])
}

model QualityFlag {
  id                  String    @id @default(cuid())
  passRunId           String
  passRun             QualityPassRun @relation(fields: [passRunId], references: [id], onDelete: Cascade)

  flagType            String    // readability, repetition, specificity, helpfulness, originality, trust, naturalness, structure, blogger_safety
  severity            String    @default("info") // critical, warning, info, suggestion
  category            String    // which module found it
  locationRef         String?   // section heading or paragraph index
  message             String    @db.Text
  suggestedFix        String?   @db.Text
  beforeSnippet       String?   @db.Text
  afterSnippet        String?   @db.Text

  status              String    @default("open") // open, accepted, rejected, fixed
  createdAt           DateTime  @default(now())

  @@index([passRunId])
}

model QualityVersion {
  id                  String    @id @default(cuid())
  passRunId           String
  passRun             QualityPassRun @relation(fields: [passRunId], references: [id], onDelete: Cascade)
  articleId           String

  versionType         String    @default("rewrite") // analysis, rewrite, final
  html                String    @db.Text
  changeSummary       String?   @db.Text // Human-readable summary of changes

  // Scores at this version
  readabilityScore    Int       @default(0)
  helpfulnessScore    Int       @default(0)
  originalityScore    Int       @default(0)
  naturalnessScore    Int       @default(0)
  trustScore          Int       @default(0)
  publishSafetyScore  Int       @default(0)
  overallScore        Int       @default(0)

  createdAt           DateTime  @default(now())

  @@index([passRunId])
  @@index([articleId])
}

// ─── FIX HISTORY & VERIFICATION ──────────────────────────────

model FixHistory {
  id               String    @id @default(cuid())
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogId           String
  postId           String
  pageUrl          String
  pageTitle        String
  issueType        String    // e.g., missing_meta_description, thin_content
  issueTitle       String    // Human-readable issue name
  fixType          String    // auto, assisted, guided
  beforeContent    String    @db.Text // Full content before fix
  afterContent     String    @db.Text // Full content after fix
  explanation      String    // Why the fix was made
  confidence       Int       @default(0) // 0-100
  safety           String    @default("safe_with_review")
  status           String    @default("pending") // pending, approved, applied, verified, failed, rolled_back
  appliedBy        String?   @db.Uuid
  appliedAt        DateTime?
  verifiedAt       DateTime?
  verificationNote String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── SCAN REPORTS (HISTORY & TRENDS) ─────────────────────────

model ScanReport {
  id               String    @id @default(cuid())
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blogId           String
  blogUrl          String
  overallScore     Int       @default(0)
  grade            String    @default("F")
  pagesScanned     Int       @default(0)
  totalIssues      Int       @default(0)
  criticalIssues   Int       @default(0)
  fixableIssues    Int       @default(0)
  categoryScores   Json      @default("{}") // { technical: 80, content: 65, ... }
  issuesSummary    Json      @default("[]") // Array of issue counts by type
  newIssues        Int       @default(0)   // Issues found that weren't in previous scan
  fixedIssues      Int       @default(0)   // Issues resolved since previous scan
  scanDurationMs   Int       @default(0)
  completedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
}
